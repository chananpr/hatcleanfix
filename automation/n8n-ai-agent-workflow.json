    {
      "id": "extract",
      "name": "\ud83d\udd0d \u0e41\u0e22\u0e01\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25 Messenger Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 340],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst entry = body.entry?.[0];\nconst messaging = entry?.messaging?.[0];\n\nif (!messaging?.message || messaging.message.is_echo) {\n  return [{ json: { skip: true } }];\n}\n\nconst psid = messaging.sender?.id;\nconst text = messaging.message?.text || '';\nconst images = (messaging.message?.attachments || [])\n  .filter(a => a.type === 'image')\n  .map(a => a.payload?.url);\n\nconst ref = messaging.referral?.ref || messaging.postback?.referral?.ref || '';\nconst adId = messaging.referral?.ad_id || '';\nconst adSource = messaging.referral?.source || '';\n\nconst userMessage = images.length > 0 && !text\n  ? '[\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32\u0e2a\u0e48\u0e07\u0e23\u0e39\u0e1b\u0e2b\u0e21\u0e27\u0e01\u0e21\u0e32\u0e43\u0e2b\u0e49\u0e14\u0e39]'\n  : text;\n\nreturn [{\n  json: {\n    skip: false,\n    psid,\n    text: userMessage,\n    images,\n    ref,\n    ad_id: adId,\n    ad_source: adSource,\n    session_id: psid\n  }\n}];"
      }
    },
    {
      "id": "if_skip",
      "name": "\u2753 \u0e21\u0e35\u0e02\u0e49\u0e2d\u0e04\u0e27\u0e32\u0e21?",
