# n8n
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST_URL=https://automation.hatfixclean.com
WEBHOOK_URL=https://automation.hatfixclean.com

# n8n Security
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_password_here

# Encryption
N8N_ENCRYPTION_KEY=your_32char_encryption_key_here

# Database (n8n internal)
DB_TYPE=mysqldb
DB_MYSQLDB_HOST=localhost
DB_MYSQLDB_PORT=3306
DB_MYSQLDB_DATABASE=n8n
DB_MYSQLDB_USER=n8n
DB_MYSQLDB_PASSWORD=

# Facebook
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=

# OpenAI / Claude (for AI extraction)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Internal API
HATFIXCLEAN_API_URL=https://api.hatfixclean.com
HATFIXCLEAN_API_SECRET=
