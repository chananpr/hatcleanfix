# Server
PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hatfixclean
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# AWS S3 File Storage
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hatfixclean-media

# Facebook / Messenger
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=
FB_APP_SECRET=

# iShip
ISHIP_API_KEY=
ISHIP_API_URL=https://api.iship.io

# n8n Webhook
N8N_WEBHOOK_SECRET=

# Admin (CORS)
ADMIN_URL=http://localhost:3001
PUBLIC_URL=http://localhost:3000
